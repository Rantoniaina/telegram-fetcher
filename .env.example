# Telegram API credentials (Required)
# Get these from https://my.telegram.org/apps
API_ID=your_api_id                    # Integer: Your Telegram API ID
API_HASH=your_api_hash                # String: Your Telegram API hash
CHANNEL_NAME=your_channel_name        # String: Target Telegram channel name

# Database settings
DATABASE_URL=sqlite:///data/telegram.db  # String: SQLite database URL (default: sqlite:///data/telegram.db)

# Media storage settings
MEDIA_PATH=data/media                 # Path: Directory to store downloaded media (default: data/media)

# Telegram client settings
SESSION_NAME=telegram_fetcher         # String: Name for the Telegram session (default: telegram_fetcher)

# Ollama LLaVA settings
# Configuration for the Ollama AI model integration
OLLAMA_BASE_URL=http://localhost:11434  # String: Local Ollama endpoint URL (default: http://localhost:11434)
OLLAMA_MODEL=llava                    # String: AI model name to use (default: llava)
OLLAMA_MAX_TOKENS=2048                # Integer: Maximum tokens for response generation (default: 2048)
OLLAMA_TEMPERATURE=0.8                # Float: Temperature for response randomness (0.0-1.0, default: 0.8)